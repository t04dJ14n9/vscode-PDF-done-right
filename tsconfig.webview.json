{
  "compilerOptions": {
    "module": "ES2020",
    "target": "ES2021",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "outDir": "dist",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node"
  },
  "include": ["webview-src/**/*", "src/shared/**/*"],
  "exclude": ["node_modules", "dist"]
}
