{
  "name": "paper-link",
  "displayName": "PaperLink",
  "description": "Bidirectional links between PDF annotations and Markdown notes",
  "version": "0.1.0",
  "publisher": "paper-link",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onCustomEditor:paperlink.pdfViewer"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "paperlink.pdfViewer",
        "displayName": "PaperLink PDF Viewer",
        "selector": [
          {
            "filenamePattern": "*.pdf"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "paperlink.createAnnotationLink",
        "title": "PaperLink: Copy PDF Link to Clipboard"
      },
      {
        "command": "paperlink.insertPdfLink",
        "title": "PaperLink: Insert PDF Link at Cursor"
      },
      {
        "command": "paperlink.showAnnotations",
        "title": "PaperLink: Show All Annotations for Current PDF"
      },
      {
        "command": "paperlink.outlineGoToPage",
        "title": "Go to Page"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "paperlink.outline",
          "name": "PDF Outline",
          "when": "paperlink.pdfOpen",
          "icon": "$(book)"
        }
      ]
    },
    "markdown.markdownItPlugins": true,
    "markdown.previewScripts": [
      "./dist/markdown-preview.js"
    ]
  },
  "scripts": {
    "compile": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "compile-tests": "tsc -p test/tsconfig.json",
    "test": "npm run compile && npm run compile-tests && node out/test/runTest.js",
    "package": "vsce package",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "copy-webpack-plugin": "^12.0.0",
    "mocha": "^11.7.5",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@embedpdf/engines": "^2.14.0",
    "@embedpdf/models": "^2.14.0",
    "@embedpdf/pdfium": "^2.14.0"
  }
}
